{{ "featured.css" | asset_url | stylesheet_tag }}

<div class="feactured-container
  {%  case section.settings.feature_layout %}
    {% when "full_width" %}
        full-width
    {% when "container" %}
        container
    {% when 'container_wrapper' %}
        container-wrapper

  {% endcase %}">

  <div class="layout">
    amars
  </div>
</div>

{% style %}
  .feactured-container {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  #shopify-section-{{ section.id }}
  .full-width {
    width: 100%;
    background: black;
    height: 500px
  }

  .full-width .layout {
    width: 100%;
    background: yellow;
    height: 100%;
  }

  #shopify-section-{{ section.id }}
  .container {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    background: red;
    height: 500px;
  }
  .container .layout {
    width: 100%;
    height: 400px;
    background: green;
    margin: 0 auto;
  }
  #shopify-section-{{ section.id }}
  .container-wrapper {
    max-width: 100%;
    width: 100%;
    background: blue;
    height: 500px;
    margin: 0 auto;
  }
  .container-wrapper .layout {
    width: 80%;
    height: 400px;
    background: black;
    margin: 0 auto;
  }
{% endstyle %}

{% schema %}
  {
    "name": "Featured",
    "tag": "section",
    "class": "featured_section",
    "settings": [
      {
        "type": "select",
        "id": "feature_layout",
        "label": "Layout",
        "default": "container",
        "options": [
          {
            "label": "Full Width",
            "value": "full_width"
          },
          {
            "label": "Cotainer",
            "value": "container"
          },
          {
            "label": "Container Wrapper",
            "value": "container_wrapper"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Featured Section"
      }
    ]
  }

{% endschema %}